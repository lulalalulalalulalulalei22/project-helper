# ============================================================
# Project Helper — 环境变量配置
# ============================================================
# 使用说明：
#   1. 复制本文件并重命名为 .env
#      cp .env.example .env
#   2. 填写下方的 API Key
#   3. 启动后端即可自动加载
# ============================================================

# ---------- 必填 ----------

# DeepSeek API Key
# 获取地址：https://platform.deepseek.com/
# 新用户注册即送额度，无需绑卡
DEEPSEEK_API_KEY=sk-your-api-key-here

# ---------- 可选 ----------

# DeepSeek 模型名称（默认 deepseek-v4-pro）
# 可选：deepseek-v4-pro / deepseek-v4-flash
# DEEPSEEK_MODEL=deepseek-v4-pro

# 后端服务端口（默认 8000）
# PORT=8000

# 前端开发服务器端口（默认 3000）
# VITE_PORT=3000
